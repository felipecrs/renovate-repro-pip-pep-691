{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "packageRules": [
        {
            // Force use of pypi simple (see note at https://github.com/renovatebot/renovate/pull/44222)
            "matchDatasources": ["pypi"],
            "registryUrls": ["https://pypi.org/simple/"]
        }
    ],
    // This doesn't work with old pypi simple implementation
    "minimumReleaseAge": "45 days"
}
