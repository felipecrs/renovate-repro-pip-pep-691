{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "packageRules": [
        {
            // Force use of pypi simple
            "matchDatasources": ["pypi"],            "registryUrls": ["https://pypi.org/simple/"]
        }
    ],
    // This doesn't work with old pypi simple implementation
    "minimumReleaseAge": "1 day"
}